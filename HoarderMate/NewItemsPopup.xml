<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

    <!-- Popup shown after mailing a banker with items not yet in their config -->
    <Frame name="HoarderMateNewItemsPopup" parent="UIParent"
           inherits="BasicFrameTemplateWithInset"
           movable="true" enableMouse="true" hidden="true"
           frameStrata="DIALOG" toplevel="true">
        <Size><AbsDimension x="300" y="280"/></Size>
        <Anchors><Anchor point="CENTER"/></Anchors>
        <Scripts>
            <OnLoad>
                self:RegisterForDrag("LeftButton")
                self.TitleText:SetText("HoarderMate")
            </OnLoad>
            <OnDragStart>self:StartMoving()</OnDragStart>
            <OnDragStop>self:StopMovingOrSizing()</OnDragStop>
        </Scripts>
        <Frames>
            <ScrollFrame name="$parentScroll" inherits="UIPanelScrollFrameTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT"     relativeTo="HoarderMateNewItemsPopup" relativePoint="TOPLEFT"     x="13"  y="-50"/>
                    <Anchor point="BOTTOMRIGHT" relativeTo="HoarderMateNewItemsPopup" relativePoint="BOTTOMRIGHT" x="-32" y="43"/>
                </Anchors>
                <ScrollChild>
                    <Frame name="HoarderMateNewItemsPopupContent">
                        <Size><AbsDimension x="240" y="1"/></Size>
                    </Frame>
                </ScrollChild>
            </ScrollFrame>
            <Button name="$parentAddBtn" inherits="UIPanelButtonTemplate" text="Add All">
                <Size><AbsDimension x="90" y="22"/></Size>
                <Anchors>
                    <Anchor point="BOTTOMLEFT" relativeTo="HoarderMateNewItemsPopup" relativePoint="BOTTOMLEFT" x="13" y="13"/>
                </Anchors>
            </Button>
            <Button name="$parentDismissBtn" inherits="UIPanelButtonTemplate" text="Dismiss">
                <Size><AbsDimension x="90" y="22"/></Size>
                <Anchors>
                    <Anchor point="BOTTOMRIGHT" relativeTo="HoarderMateNewItemsPopup" relativePoint="BOTTOMRIGHT" x="-13" y="13"/>
                </Anchors>
            </Button>
        </Frames>
        <Layers>
            <Layer level="ARTWORK">
                <FontString name="$parentMessage" inherits="GameFontNormalSmall"
                            justifyH="LEFT" justifyV="TOP">
                    <Anchors>
                        <Anchor point="TOPLEFT"  relativeTo="HoarderMateNewItemsPopup" relativePoint="TOPLEFT"  x="13"  y="-30"/>
                        <Anchor point="TOPRIGHT" relativeTo="HoarderMateNewItemsPopup" relativePoint="TOPRIGHT" x="-13" y="-30"/>
                    </Anchors>
                    <Size><AbsDimension x="0" y="18"/></Size>
                </FontString>
            </Layer>
        </Layers>
    </Frame>

</Ui>
